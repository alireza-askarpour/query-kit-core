{
  "name": "query-kit-core",
  "version": "1.0.3",
  "description": "Extensible query filter parser and adapter pipeline for NestJS applications.",
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "files": [
    "lib",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "require": "./lib/index.js",
      "default": "./lib/index.js"
    }
  },
  "sideEffects": false,
  "scripts": {
    "build": "rm -rf lib_tmp && tsc -p tsconfig.build.json --outDir lib_tmp && rm -rf lib && mv lib_tmp lib",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "build:test": "rm -rf .tmp-test && tsc -p tsconfig.test.json && cp -R lib .tmp-test/lib",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\" \"*.{json,md}\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\" \"*.{json,md}\"",
    "test": "pnpm build && pnpm build:test && node --test .tmp-test/test/**/*.test.js",
    "test:coverage": "pnpm build && pnpm build:test && node --test --experimental-test-coverage .tmp-test/test/**/*.test.js",
    "bench:validation-reuse": "pnpm build && pnpm build:test && node .tmp-test/test/benchmarks/validation-reuse.bench.js",
    "bench:sc-parser": "pnpm build && pnpm build:test && node .tmp-test/test/benchmarks/sc-parser.bench.js",
    "bench:mc-parser": "pnpm build && pnpm build:test && node .tmp-test/test/benchmarks/mc-parser.bench.js",
    "prepublishOnly": "pnpm lint && pnpm test"
  },
  "keywords": [
    "nestjs",
    "query",
    "filter",
    "mongodb",
    "mongoose",
    "sequelize",
    "typeorm",
    "adapter"
  ],
  "author": "Alireza Askarpour",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/alireza-askarpour/query-kit.git"
  },
  "homepage": "https://github.com/alireza-askarpour/query-kit#readme",
  "bugs": {
    "url": "https://github.com/alireza-askarpour/query-kit/issues"
  },
  "packageManager": "pnpm@10.22.0",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.19",
    "@nestjs/core": "^11.1.19",
    "sequelize": "^6.37.8"
  },
  "peerDependencies": {
    "mongoose": ">=8"
  },
  "peerDependenciesMeta": {
    "mongoose": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "@nestjs/cli": "^11.0.10",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.39.1",
    "@typescript-eslint/parser": "^8.39.1",
    "eslint": "^9.31.0",
    "globals": "^16.3.0",
    "prettier": "^3.6.2",
    "typescript": "^5.9.2"
  }
}
